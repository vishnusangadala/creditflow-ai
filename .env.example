# Copy to .env and fill in. docker-compose reads this file.

# Required — the agents call OpenAI.
OPENAI_API_KEY=sk-...

# Optional — defaults to gpt-4o-mini.
OPENAI_MODEL=gpt-4o-mini

# Optional — LangSmith observability. Leave tracing false to run without it.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=creditflow-ai
